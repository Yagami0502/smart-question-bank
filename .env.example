# Required by the API service.
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret

# Used by nginx CORS proxying in Docker.
CORS_ORIGINS=http://localhost

# Optional defaults for the client-side AI settings form.
# The API key is intentionally not stored in source control.
VITE_AI_BASE_URL=https://api.openai.com
VITE_AI_MODEL=gpt-4o-mini
